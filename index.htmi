<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EL AL Business Circle | מדריך לסוכני אמסלם</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --navy-deep:#081426;
  --navy:#0d1f3c;
  --navy-card:#122a4e;
  --navy-line:#1e3a63;
  --teal:#1bb0ce;
  --teal-soft:rgba(27,176,206,.12);
  --gold:#b08d3e;
  --silver:#9aa3ad;
  --white:#f4f7fb;
  --muted:#93a5c1;
  --amber:#ffc861;
  --green:#4ade80;
  --red:#ff6b6b;
  --mono:"Consolas","Courier New",ui-monospace,monospace;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  font-family:'Heebo',sans-serif;
  background:var(--navy-deep);
  color:var(--white);
  line-height:1.6;
  min-height:100vh;
}
::selection{background:var(--teal);color:var(--navy-deep)}
button:focus-visible,input:focus-visible{outline:2px solid var(--teal);outline-offset:2px}
@media(prefers-reduced-motion:reduce){
  html{scroll-behavior:auto}
  .gds-panel.active{animation:none}
}

header{
  background:linear-gradient(180deg,#0a1a33 0%,var(--navy-deep) 100%);
  border-bottom:1px solid var(--navy-line);
  padding:18px 24px;
  display:flex;align-items:center;justify-content:space-between;gap:16px;
}
.brand{display:flex;align-items:center;gap:14px}
.brand .logo-img{
  background:#fff;border-radius:12px;padding:6px 12px;
  display:flex;align-items:center;
}
.brand .logo-img img{height:38px;width:auto;display:block}
@media(max-width:640px){.brand .logo-img img{height:30px}}
.brand .logo{
  font-weight:900;font-size:1.25rem;letter-spacing:.02em;color:var(--white);
}
.brand .logo span{color:var(--teal)}
.brand .divider{width:1px;height:26px;background:var(--navy-line)}
.brand .sub{font-size:.8rem;color:var(--muted);font-weight:500}

.hero{
  text-align:center;
  padding:40px 24px 30px;
  background:
    radial-gradient(ellipse 60% 50% at 50% -10%,rgba(27,176,206,.18),transparent),
    radial-gradient(ellipse 40% 35% at 85% 15%,rgba(0,51,153,.25),transparent);
}
.hero h1{
  font-size:clamp(1.8rem,4vw,2.5rem);font-weight:900;line-height:1.15;
  letter-spacing:.01em;
}
.hero h1 .en{direction:ltr;display:inline-block}

/* deadline strip — essential: old codes removal date */
.deadline{
  display:inline-flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:center;
  margin-top:16px;padding:8px 18px;border-radius:99px;
  background:rgba(255,107,107,.08);border:1px solid rgba(255,107,107,.45);
  font-size:.85rem;font-weight:600;
}
.deadline .old-code{
  font-family:var(--mono);font-size:.8rem;font-weight:700;direction:ltr;
  color:var(--red);text-decoration:line-through;
}
.deadline b{color:var(--red)}

.sticky-wrap{
  position:sticky;top:0;z-index:50;
  background:rgba(8,20,38,.96);backdrop-filter:blur(10px);
  border-bottom:1px solid var(--navy-line);
}

.gds-bar{
  padding:12px 16px;text-align:center;
  display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;
}
.gds-label{font-size:.85rem;color:var(--muted);font-weight:600;}
.gds-btns{display:inline-flex;gap:8px;flex-wrap:wrap;justify-content:center;}
.gds-btn{
  font-family:'Heebo',sans-serif;font-weight:700;font-size:.85rem;
  padding:7px 16px;border-radius:99px;cursor:pointer;
  background:var(--navy-card);color:var(--muted);
  border:1px solid var(--navy-line);
  transition:all .2s;direction:ltr;
}
.gds-btn:hover{color:var(--white);border-color:var(--teal)}
.gds-btn.active{background:var(--teal);color:var(--navy-deep);border-color:var(--teal)}
.gds-btn .code{opacity:.7;font-weight:500}
.gds-btn.active .code{opacity:.85}

.smart-bar{
  background:rgba(27,176,206,.05);
  border-top:1px dashed var(--navy-line);
  padding:12px 16px;
  display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;
}
.smart-bar-title{
  font-size:.85rem;font-weight:800;color:var(--teal);display:flex;align-items:center;gap:6px;
}
.smart-inputs{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;}
.smart-input{
  background:var(--navy-deep);border:1px solid var(--navy-line);
  color:var(--white);font-family:var(--mono);font-size:.85rem;font-weight:600;
  padding:6px 12px;border-radius:8px;width:130px;text-align:center;
  text-transform:uppercase;
}
.smart-input:focus{outline:none;border-color:var(--teal);background:var(--navy-card)}
.smart-input::placeholder{color:var(--muted);font-weight:400;font-size:.8rem;font-family:'Heebo',sans-serif;text-transform:none}
.smart-clear{
  font-family:'Heebo',sans-serif;font-size:.75rem;font-weight:700;
  background:transparent;color:var(--muted);border:1px solid var(--navy-line);
  border-radius:8px;padding:6px 12px;cursor:pointer;transition:all .2s;
}
.smart-clear:hover{color:var(--red);border-color:var(--red)}

main{max-width:860px;margin:0 auto;padding:24px 20px 80px}
section{margin-top:40px;scroll-margin-top:140px}
.sec-head{display:flex;align-items:center;gap:14px;margin-bottom:8px}
.sec-num{
  flex:none;width:34px;height:34px;border-radius:10px;
  background:var(--teal-soft);border:1px solid var(--teal);
  color:var(--teal);font-weight:900;font-size:1rem;
  display:flex;align-items:center;justify-content:center;
}
.sec-head h2{font-size:1.3rem;font-weight:800}
.sec-sub{color:var(--muted);margin-bottom:16px;font-size:.95rem;}

.gds-panel{display:none}
.gds-panel.active{display:block;animation:fadeIn .3s}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

.term{
  border-radius:14px;overflow:hidden;margin-top:10px;
  border:1px solid var(--navy-line);
  font-family:var(--mono);
}
.term-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:8px 14px;font-family:'Heebo',sans-serif;font-size:.8rem;font-weight:600;
  background:rgba(255,255,255,.04);border-bottom:1px solid rgba(255,255,255,.08);
  color:var(--muted);
}
.term-body{padding:6px 0}
.cmd-row{
  display:flex;align-items:center;justify-content:space-between;gap:12px;
  padding:9px 16px;
}
.cmd-row.main-cmd{background:rgba(255,200,97,.05);}
.cmd-row + .cmd-row{border-top:1px dashed rgba(255,255,255,.09)}
.cmd-label{font-family:'Heebo',sans-serif;font-size:.82rem;color:var(--muted);flex:none;max-width:40%;line-height:1.3}
.cmd-label .star{color:var(--amber);margin-inline-end:4px}
.cmd-code-wrap{display:flex;align-items:center;gap:8px;direction:ltr;flex:1;justify-content:flex-start;min-width:0}
.cmd-code{font-size:.92rem;font-weight:600;direction:ltr;unicode-bidi:embed;word-break:break-all;}
.cmd-code .ph{background:rgba(255,200,97,.2);color:var(--amber);border-radius:4px;padding:0 3px;font-weight:800;}
.cmd-code .ph.filled,.mono-hl .filled{background:rgba(74,222,128,.18);color:var(--green)}

/* GDS Themes */
.term.amadeus{background:#0b1f5e}
.term.amadeus .cmd-code{color:#cfe0ff}
.term.sabre{background:#101418}
.term.sabre .cmd-code{color:#e8e8e8}
.term.worldspan{background:#04240f}
.term.worldspan .cmd-code{color:#8ff0a8}
.term.galileo{background:#04240f}
.term.galileo .cmd-code{color:#8ff0a8}

.copy-btn{
  flex:none;font-family:'Heebo',sans-serif;font-size:.72rem;font-weight:700;
  background:transparent;color:var(--muted);border:1px solid rgba(255,255,255,.2);
  border-radius:8px;padding:3px 10px;cursor:pointer;transition:all .2s;
}
.copy-btn:hover{color:var(--teal);border-color:var(--teal)}
.copy-btn.copied{color:var(--green);border-color:var(--green)}

.note{
  display:flex;gap:12px;align-items:flex-start;
  background:var(--teal-soft);border:1px solid rgba(27,176,206,.35);
  border-radius:14px;padding:12px 16px;margin-top:12px;
  font-size:.9rem;color:var(--white);
}
.note.warn{background:rgba(255,200,97,.08);border-color:rgba(255,200,97,.4)}
.note .ico{flex:none;line-height:1.5}
.note b{font-weight:700}

.methods{display:grid;gap:16px;margin-top:16px}
.method{background:var(--navy-card);border:1px solid var(--navy-line);border-radius:16px;padding:18px;}
.method h3{font-size:1.05rem;font-weight:800;color:var(--teal);margin-bottom:6px}
.method p{color:var(--muted);font-size:.92rem}
.method p b{color:var(--white)}
.method ul{margin:10px 24px 0 0;color:var(--muted);font-size:.9rem}
.method ul b{color:var(--white)}
.mono-hl{font-family:var(--mono);direction:ltr;unicode-bidi:embed;font-weight:700;color:var(--amber);background:rgba(255,200,97,.1);border-radius:5px;padding:0 5px;}

/* auto-ticketing fields — essential from source doc */
.fields{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:12px}
@media(max-width:680px){.fields{grid-template-columns:1fr}}
.field{
  background:var(--navy-deep);border:1px solid var(--navy-line);border-radius:12px;
  padding:14px;text-align:center;
}
.field .fname{font-family:var(--mono);font-weight:800;font-size:.85rem;color:var(--teal);direction:ltr;letter-spacing:.05em}
.field .fval{margin-top:4px;font-size:.83rem;color:var(--muted)}
.field .fex{
  margin-top:8px;font-family:var(--mono);font-size:.78rem;direction:ltr;
  color:var(--amber);background:rgba(255,200,97,.08);border-radius:8px;padding:3px 8px;
  display:inline-block;
}

footer{border-top:1px solid var(--navy-line);margin-top:40px;padding:24px;text-align:center;color:var(--muted);font-size:.85rem;}
footer p{margin-top:4px}
</style>
</head>
<body>

<header>
  <div class="brand">
    <div class="logo-img"><img src="data:image/jpeg;base64," alt="Amsalem 24 Hours — Global Travel Management"></div>
    <div class="divider"></div>
    <div class="sub">מדריך סוכנים מהיר</div>
  </div>
</header>

<div class="hero">
  <h1><span class="en">EL AL Business Circle</span></h1>
  <p style="color:var(--muted);margin-top:8px">מדריך פקודות לזיהוי ותמחור — יש להשתמש בקודים החדשים בלבד.</p>
  <div class="deadline">
    <span>⏳ הקודים הישנים</span>
    <span class="old-code">COR02</span><span class="old-code">COR03</span><span class="old-code">COR04</span><span class="old-code">COR05</span>
    <span>מוסרים מהמערכת ב-<b>21.07.2026</b></span>
  </div>
</div>

<div class="sticky-wrap">
  <div class="gds-bar" role="tablist" aria-label="בחירת מערכת הפצה">
    <span class="gds-label">מערכת:</span>
    <span class="gds-btns">
      <button class="gds-btn active" data-gds="amadeus" role="tab" aria-selected="true">Amadeus <span class="code">1A</span></button>
      <button class="gds-btn" data-gds="sabre" role="tab" aria-selected="false">Sabre <span class="code">1S</span></button>
      <button class="gds-btn" data-gds="worldspan" role="tab" aria-selected="false">Worldspan <span class="code">1P</span></button>
      <button class="gds-btn" data-gds="galileo" role="tab" aria-selected="false">Galileo <span class="code">1G</span></button>
    </span>
  </div>

  <div class="smart-bar">
    <div class="smart-bar-title">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      השלמה חכמה:
    </div>
    <div class="smart-inputs">
      <input type="text" id="inp-pricing" class="smart-input" placeholder="קוד מזהה חברה" aria-label="קוד מזהה חברה">
      <input type="text" id="inp-company" class="smart-input" placeholder="מספר חברה" aria-label="מספר חברה">
      <input type="text" id="inp-tier" class="smart-input" placeholder="(DS) דירוג" aria-label="דירוג חברה" maxlength="2">
      <input type="text" id="inp-agent" class="smart-input" placeholder="אותיות סוכן" aria-label="אותיות סוכן">
      <button class="smart-clear" id="smart-clear" type="button">ניקוי</button>
    </div>
  </div>
</div>

<main>

<section id="identify">
  <div class="sec-head"><div class="sec-num">1</div><h2>זיהוי חברה בהזמנה</h2></div>
  <p class="sec-sub">הזן פקודה זו כדי לעדכן את החברה בהזמנה לצרכי תפעול.</p>

  <!-- Amadeus -->
  <div class="gds-panel amadeus active">
    <div class="term amadeus">
      <div class="term-head"><span>פקודת עדכון</span><span dir="ltr">1A · Amadeus</span></div>
      <div class="term-body">
        <div class="cmd-row">
          <span class="cmd-label">עדכון החברה</span>
          <span class="cmd-code-wrap"><span class="cmd-code">SR CO<span class="ph ph-tier">XX</span>-<span class="ph ph-company">xxxxx</span></span>
          <button class="copy-btn">העתק</button></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Sabre -->
  <div class="gds-panel sabre">
    <div class="term sabre">
      <div class="term-head"><span>פקודת עדכון</span><span dir="ltr">1S · Sabre</span></div>
      <div class="term-body">
        <div class="cmd-row">
          <span class="cmd-label">עדכון החברה</span>
          <span class="cmd-code-wrap"><span class="cmd-code">3CO<span class="ph ph-tier">XX</span>/<span class="ph ph-company">xxxxx</span>-1.1</span>
          <button class="copy-btn">העתק</button></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Worldspan -->
  <div class="gds-panel worldspan">
    <div class="term worldspan">
      <div class="term-head"><span>פקודת עדכון</span><span dir="ltr">1P · Worldspan</span></div>
      <div class="term-body">
        <div class="cmd-row">
          <span class="cmd-label">עדכון החברה</span>
          <span class="cmd-code-wrap"><span class="cmd-code">3SAN1CO<span class="ph ph-tier">XX</span> <span class="ph ph-company">xxxxx</span></span>
          <button class="copy-btn">העתק</button></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Galileo -->
  <div class="gds-panel galileo">
    <div class="term galileo">
      <div class="term-head"><span>פקודת עדכון</span><span dir="ltr">1G · Galileo</span></div>
      <div class="term-body">
        <div class="cmd-row">
          <span class="cmd-label">עדכון החברה</span>
          <span class="cmd-code-wrap"><span class="cmd-code">SI.P1/SSRCO<span class="ph ph-tier">XX</span>LYHK1/<span class="ph ph-company">xxxxx</span></span>
          <button class="copy-btn">העתק</button></span>
        </div>
      </div>
    </div>
  </div>

  <div class="note warn">
    <span class="ico">⚠️</span>
    <div><b>XX</b> = דירוג החברה (<span dir="ltr">DS / DG / DP</span>) · <b>xxxxx</b> = מספר החברה. עדכון מספר החברה חשוב לזיהוי תפעולי של הלקוחות במערכת.</div>
  </div>
</section>

<section id="pricing">
  <div class="sec-head"><div class="sec-num">2</div><h2>תמחור מחירון עסקי</h2></div>
  <p class="sec-sub">בחר את פקודת התמחור המתאימה. התמחור מתבסס על הקוד המזהה.</p>

  <!-- Amadeus -->
  <div class="gds-panel amadeus active">
    <div class="term amadeus">
      <div class="term-head"><span>פקודות תמחור</span><span dir="ltr">1A · Amadeus</span></div>
      <div class="term-body">
        <div class="cmd-row">
          <span class="cmd-label">צפייה במחירים</span>
          <span class="cmd-code-wrap"><span class="cmd-code">FQDTLVNYC/03NOV/ALY/R,U*<span class="ph ph-pricing">xxxxx</span></span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row main-cmd">
          <span class="cmd-label"><span class="star">⭐</span> תמחור מחיר הסכם</span>
          <span class="cmd-code-wrap"><span class="cmd-code">FXP/R,U*<span class="ph ph-pricing">xxxxx</span></span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row">
          <span class="cmd-label">שילוב עם מפורסם</span>
          <span class="cmd-code-wrap"><span class="cmd-code">FXP/R,U*<span class="ph ph-pricing">xxxxx</span>,P</span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row">
          <span class="cmd-label">שילוב Publish over the water</span>
          <span class="cmd-code-wrap"><span class="cmd-code">FXP/R,U*<span class="ph ph-pricing">xxxxx</span>,OCC-LY</span>
          <button class="copy-btn">העתק</button></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Sabre -->
  <div class="gds-panel sabre">
    <div class="term sabre">
      <div class="term-head"><span>פקודות תמחור</span><span dir="ltr">1S · Sabre</span></div>
      <div class="term-body">
        <div class="cmd-row">
          <span class="cmd-label">צפייה במחירים</span>
          <span class="cmd-code-wrap"><span class="cmd-code">FQTLVNYC03NOV-LY¥UI<span class="ph ph-pricing">xxxxx</span></span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row main-cmd">
          <span class="cmd-label"><span class="star">⭐</span> תמחור מחיר הסכם</span>
          <span class="cmd-code-wrap"><span class="cmd-code">WPI<span class="ph ph-pricing">xxxxx</span>¥XC</span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row">
          <span class="cmd-label">שילוב עם מפורסם</span>
          <span class="cmd-code-wrap"><span class="cmd-code">WPI<span class="ph ph-pricing">xxxxx</span></span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row">
          <span class="cmd-label">שילוב Publish over the water</span>
          <span class="cmd-code-wrap"><span class="cmd-code">WPC-LY¥ALY<br>WPC-LY¥ALY¥I<span class="ph ph-pricing">xxxxx</span>¥XC</span>
          <button class="copy-btn">העתק</button></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Worldspan -->
  <div class="gds-panel worldspan">
    <div class="term worldspan">
      <div class="term-head"><span>פקודות תמחור</span><span dir="ltr">1P · Worldspan</span></div>
      <div class="term-body">
        <div class="cmd-row">
          <span class="cmd-label">צפייה במחירים</span>
          <span class="cmd-code-wrap"><span class="cmd-code">4FTLVNYCSR-LY/L03NOV/@@C<span class="ph ph-pricing">xxxxx</span>.AC</span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row main-cmd">
          <span class="cmd-label"><span class="star">⭐</span> תמחור מחיר הסכם</span>
          <span class="cmd-code-wrap"><span class="cmd-code">4P*FSR#/@@<span class="ph ph-pricing">xxxxx</span>.AC</span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row">
          <span class="cmd-label">שילוב עם מפורסם</span>
          <span class="cmd-code-wrap"><span class="cmd-code">4P*-S1-SIPNA1#S2-QY1NA#FSR#/@@<span class="ph ph-pricing">xxxxx</span></span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row">
          <span class="cmd-label">שילוב Publish over the water</span>
          <span class="cmd-code-wrap"><span class="cmd-code">4P*-OCLY#FSR#/@@<span class="ph ph-pricing">xxxxx</span>.AC</span>
          <button class="copy-btn">העתק</button></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Galileo -->
  <div class="gds-panel galileo">
    <div class="term galileo">
      <div class="term-head"><span>פקודות תמחור</span><span dir="ltr">1G · Galileo</span></div>
      <div class="term-body">
        <div class="cmd-row">
          <span class="cmd-label">צפייה במחירים</span>
          <span class="cmd-code-wrap"><span class="cmd-code">FDTLVNYC03NOV/LY-PRI-:<span class="ph ph-pricing">xxxxx</span></span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row main-cmd">
          <span class="cmd-label"><span class="star">⭐</span> תמחור מחיר הסכם</span>
          <span class="cmd-code-wrap"><span class="cmd-code">FQ-:<span class="ph ph-pricing">xxxxx</span><br>FQ-:<span class="ph ph-pricing">xxxxx</span>/OCLY</span>
          <button class="copy-btn">העתק</button></span>
        </div>
        <div class="cmd-row">
          <span class="cmd-label">שילוב עם מפורסם</span>
          <span class="cmd-code-wrap"><span class="cmd-code">FQS1-:<span class="ph ph-pricing">xxxxx</span>.2</span>
          <button class="copy-btn">העתק</button></span>
        </div>
      </div>
    </div>
  </div>

  <div class="note warn">
    <span class="ico">✉️</span>
    <div>במקרה של בעיה או שאלה בנושא התמחור, ניתן לפנות לצוות אל על במייל: <a href="mailto:businesscircle@elal.co.il" dir="ltr" style="color:var(--teal);font-weight:700;text-decoration:none">businesscircle@elal.co.il</a></div>
  </div>
</section>



<section id="ticketing">
  <div class="sec-head"><div class="sec-num">3</div><h2>כרטוס</h2></div>

  <div class="methods">

    <!-- Amadeus Specific Notes -->
    <div class="gds-panel amadeus active">
      <div class="note warn" style="margin-top:0;margin-bottom:16px;">
        <span class="ico">⚠️</span>
        <div>בשדה <span dir="ltr">Tour Code</span> חובה לכלול קידומת COM ואת מספר החברה, בפורמט:
        <span class="mono-hl" dir="ltr" style="display:inline-block;margin-top:4px;">FT*COM<span class="ph-company amadeus-note-company">xxxxx</span>//<span class="ph-agent amadeus-note-agent">YY</span></span>
        <span style="color:var(--muted);font-size:.82rem">(YY = אותיות הסוכן)</span></div>
      </div>
      <div class="note" style="margin-top:0;margin-bottom:16px;">
        <span class="ico">💡</span>
        <div>צורת תשלום <span class="mono-hl" dir="ltr">FPCASH</span> תתאפשר <b>אך ורק</b> אם אותיות הסוכן תואמות לאותיות <span dir="ltr">LY</span>.</div>
      </div>
    </div>

    <!-- Worldspan Specific Notes -->
    <div class="gds-panel worldspan">
      <div class="note" style="margin-top:0;margin-bottom:16px;">
        <span class="ico">💡</span>
        <div>פקודת כרטוס עם הסכם חברה (משלבת את מספר החברה ואותיות הסוכן):
        <span class="mono-hl" dir="ltr">EZ#CLY#IT<span class="ph-company">xxxxx</span>**<span class="ph-agent">YY</span></span>
        <span style="color:var(--muted);font-size:.82rem">(YY = אותיות הסוכן)</span></div>
      </div>
    </div>

    <div class="method">
      <h3>כרטוס אוטומטי (תמחור ממוכן)</h3>
      <p>בכרטוס באמצעות <b>קוד הזיהוי של החברה</b>, המידע נכנס אוטומטית אל השדות:</p>
      <div class="fields">
        <div class="field">
          <div class="fname">ENDORSEMENT</div>
          <div class="fval">שם החברה וקוד התמחור</div>
          <div class="fex">HELMANS CORP/CPR03</div>
        </div>
        <div class="field">
          <div class="fname">FARE BASIS</div>
          <div class="fval">קוד התמחור (צמוד)</div>
          <div class="fex">MF3PR/CPR03</div>
        </div>
        <div class="field">
          <div class="fname">TOUR CODE</div>
          <div class="fval">מספר החברה</div>
          <div class="fex">COM12919</div>
        </div>
      </div>
    </div>

    <div class="method">
      <h3>תמחור ידני (דרך המוקד)</h3>
      <ul>
        <li><span dir="ltr">Fare Basis 2</span>: קוד מזהה לתמחור.</li>
        <li><span dir="ltr">Endorsement &amp; Tour Code</span>: מספר חברה <span class="mono-hl">COM<span class="ph-company">xxxxx</span></span>.</li>
      </ul>
    </div>

    <div class="method">
      <h3>כרטוס מחירון Publish</h3>
      <p>יש להזין בשדה <span dir="ltr">Tour Code</span> את מספר החברה: <span class="mono-hl">COM<span class="ph-company">xxxxx</span></span> (ללא רווחים).</p>
    </div>

  </div>
</section>

</main>

<footer>
  <div>AMSALEM TOURS · EL AL Business Circle</div>
  <p>שאלות תמחור — <a href="mailto:businesscircle@elal.co.il" dir="ltr" style="color:var(--teal);text-decoration:none">businesscircle@elal.co.il</a> · תמחור ידני — מוקד הסוכנים</p>
</footer>

<script>
const btns = document.querySelectorAll('.gds-btn');
const panels = document.querySelectorAll('.gds-panel');

// GDS Switcher
btns.forEach(btn => {
  btn.addEventListener('click', () => {
    const g = btn.dataset.gds;
    btns.forEach(b => {
      b.classList.toggle('active', b === btn);
      b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
    });
    panels.forEach(p => p.classList.toggle('active', p.classList.contains(g)));
  });
});

// Smart Updater
const inpPricing = document.getElementById('inp-pricing');
const inpCompany = document.getElementById('inp-company');
const inpTier = document.getElementById('inp-tier');
const inpAgent = document.getElementById('inp-agent');
const inputs = [inpPricing, inpCompany, inpTier, inpAgent];

const DEFAULTS = { pricing: 'xxxxx', company: 'xxxxx', tier: 'XX', agent: 'YY' };

function setPh(selector, value, def) {
  const filled = value !== def;
  document.querySelectorAll(selector).forEach(el => {
    el.textContent = value;
    el.classList.toggle('filled', filled);
  });
}

function updateFields() {
  const vPricing = inpPricing.value.trim().toUpperCase() || DEFAULTS.pricing;
  const vCompany = inpCompany.value.trim().toUpperCase() || DEFAULTS.company;
  const vTier = inpTier.value.trim().toUpperCase() || DEFAULTS.tier;
  const vAgent = inpAgent.value.trim().toUpperCase() || DEFAULTS.agent;

  setPh('.ph-pricing', vPricing, DEFAULTS.pricing);
  setPh('.ph-company', vCompany, DEFAULTS.company);
  setPh('.ph-tier', vTier, DEFAULTS.tier);
  setPh('.ph-agent', vAgent, DEFAULTS.agent);

  // Update Copy Buttons Data (row commands)
  document.querySelectorAll('.cmd-row').forEach(row => {
    const codeSpan = row.querySelector('.cmd-code');
    const btn = row.querySelector('.copy-btn');
    if (codeSpan && btn) {
      let textToCopy = codeSpan.innerHTML.replace(/<br\s*\/?>/gi, '\r\n');
      textToCopy = textToCopy.replace(/<[^>]+>/g, '');
      const tmp = document.createElement('textarea');
      tmp.innerHTML = textToCopy;
      btn.dataset.copy = tmp.value;
    }
  });
}

inputs.forEach(input => input.addEventListener('input', updateFields));

document.getElementById('smart-clear').addEventListener('click', () => {
  inputs.forEach(i => i.value = '');
  updateFields();
});

// Initial run to populate data-copy attributes
updateFields();

// Copy functionality — blocked until real values are entered, to prevent
// sending a command with xxxxx / XX placeholders into a live terminal
const hasPlaceholders = t => /XXXXX/i.test(t) || /COXX/.test(t);

document.querySelectorAll('.copy-btn').forEach(b => {
  b.addEventListener('click', async () => {
    const text = b.dataset.copy;
    if (hasPlaceholders(text)) {
      b.textContent = 'הזן קוד למעלה';
      setTimeout(() => b.textContent = 'העתק', 1800);
      return;
    }
    try {
      await navigator.clipboard.writeText(text);
      b.textContent = 'הועתק ✓'; b.classList.add('copied');
      setTimeout(() => { b.textContent = 'העתק'; b.classList.remove('copied'); }, 1600);
    } catch (e) {
      const ta = document.createElement('textarea'); ta.value = text;
      document.body.appendChild(ta); ta.select(); document.execCommand('copy'); ta.remove();
      b.textContent = 'הועתק ✓'; setTimeout(() => b.textContent = 'העתק', 1600);
    }
  });
});
</script>
</body>
</html>
